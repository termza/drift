# Copy this file to `.env` and edit the values.

# Required: shared password the Drift mobile app uses to sign in.
SYNC_PASSWORD=changeme

# Optional: path on the host to the folder of audio files you want to
# expose. Defaults to ./media (sibling of docker-compose.yml).
# Examples:
#   Windows: MEDIA_DIR_HOST=C:/Users/you/Music
#   Linux:   MEDIA_DIR_HOST=/srv/audiobooks
#   Mac:     MEDIA_DIR_HOST=/Users/you/Music
MEDIA_DIR_HOST=./media
